#!/usr/bin/env python3
import sys
import os
import subprocess
import shutil

# Add scripts to path so we can import core
base_dir = os.path.dirname(os.path.abspath(__file__))
sys.path.append(os.path.join(base_dir, "scripts"))


def launch_tui():
    """Tries to launch the Rust TUI if it exists, or offers to build it."""
    tui_path = os.path.join(
        base_dir, "promptbook-tui", "target", "release", "promptbook-tui"
    )
    tui_dir = os.path.join(base_dir, "promptbook-tui")
    is_stale = False
    if os.path.exists(tui_path):
        tui_mtime = os.path.getmtime(tui_path)
        src_dir = os.path.join(tui_dir, "src")
        for root, _, files in os.walk(src_dir):
            for f in files:
                if f.endswith(".rs"):
                    f_path = os.path.join(root, f)
                    if os.path.getmtime(f_path) > tui_mtime:
                        is_stale = True
                        break
            if is_stale:
                break
    # Offer rebuild if binary is missing OR stale
    if (
        (not os.path.exists(tui_path) or is_stale)
        and sys.stdin.isatty()
        and shutil.which("cargo")
    ):
        reason = "not found" if not os.path.exists(tui_path) else "out of date"
        print(f"\n\033[1;33mpromptbook Explorer (TUI) binary is {reason}.\033[0m")
        try:
            choice = input(
                f"Would you like to {'re' if is_stale else ''}build it now? (y/N): "
            ).lower()
            if choice == "y":
                print(
                    "\n\033[1;36mBuilding TUI (release mode)... This may take a minute.\033[0m"
                )
                result = subprocess.run(["cargo", "build", "--release"], cwd=tui_dir)
                if result.returncode == 0:
                    print("\033[1;32mBuild successful! Launching...\033[0m\n")
                    os.execv(tui_path, [tui_path])
                else:
                    print(
                        "\n\033[1;31mBuild failed. Falling back to CLI helper.\033[0m\n"
                    )
        except (KeyboardInterrupt, EOFError):
            print("\n")
            pass
    if os.path.exists(tui_path):
        try:
            # Use os.execv to replace current process with TUI
            os.execv(tui_path, [tui_path])
        except Exception:
            pass  # Fallback to CLI helper if exec fails
    return False


if __name__ == "__main__":
    # If no arguments and interactive, try to launch or build the TUI
    if len(sys.argv) == 1 and sys.stdin.isatty():
        launch_tui()
    # Otherwise, fallback to the standard CLI helper logic
    try:
        from promptbook.cli import main
    except ImportError:
        sys.path.append(os.path.join(base_dir, "scripts"))
        from promptbook.cli import main
    main()
